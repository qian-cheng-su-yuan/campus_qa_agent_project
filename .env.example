# ===== 项目基础配置 =====
APP_NAME=Campus QA Agent
APP_ENV=dev
API_HOST=127.0.0.1
API_PORT=8000
WEB_PORT=8501

# ===== 大模型配置 =====
# 支持 qwen / deepseek / openai_compatible / mock
LLM_PROVIDER=qwen

# 阿里云百炼示例：
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# DeepSeek 示例：
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_API_KEY=
LLM_TIMEOUT=60

# ===== RAG 配置 =====
KNOWLEDGE_BASE_DIR=data/knowledge_base
UPLOAD_DIR=data/uploads
LOG_DIR=logs
CHUNK_SIZE=450
CHUNK_OVERLAP=80
DEFAULT_TOP_K=4

# ===== 安全演示配置 =====
# true 表示 API Key 为空时启用本地兜底回答
ENABLE_LOCAL_FALLBACK=true
